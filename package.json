{
  "name": "es-seguro-volver",
  "version": "2.0.0",
  "private": true,
  "description": "Plataforma ciudadana de triaje estructural tras un sismo. Cloudflare Pages + Functions + D1 + R2.",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev",
    "db:init:local": "wrangler d1 execute esv-db --local --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute esv-db --local --file=./seed.sql",
    "db:init:remote": "wrangler d1 execute esv-db --remote --file=./schema.sql",
    "deploy": "wrangler pages deploy"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
